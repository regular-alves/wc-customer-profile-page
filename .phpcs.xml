<?xml version="1.0"?>
<ruleset name="WooCommerce Customer Profile Page">
    <description>Coding standards for the WooCommerce Customer Profile Page plugin.</description>

    <file>.</file>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>

    <rule ref="WordPress-VIP-Go">
        <exclude name="WordPressVIPMinimum.JS.StringConcat"/>
        <exclude name="WordPressVIPMinimum.JS.DangerouslySetInnerHTML"/>
        <exclude name="WordPressVIPMinimum.JS.StrippingTags"/>
        <exclude name="WordPressVIPMinimum.JS.Window"/>
        <exclude name="WordPressVIPMinimum.JS.InnerHTML"/>
        <exclude name="WordPressVIPMinimum.JS.HTMLExecutingFunctions"/>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wc-customer-profile-page"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wccp"/>
                <element value="WCCustomerProfilePage"/>
            </property>
        </properties>
    </rule>
</ruleset>
