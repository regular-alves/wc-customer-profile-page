<?xml version="1.0"?>
<ruleset name="WooCommerce Customer Profile Page">
    <description>Coding standards for the WooCommerce Customer Profile Page plugin.</description>

    <file>.</file>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/tests/*</exclude-pattern>
    <exclude-pattern>/node_modules/*</exclude-pattern>

    <rule ref="WordPress-VIP-Go"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array" value="wc-customer-profile-page"/>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array" value="wccp,WCCustomerProfilePage"/>
        </properties>
    </rule>
</ruleset>
