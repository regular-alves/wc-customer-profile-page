{
    "name": "regular-alves/customer-profile-page-for-woocommerce",
    "description": "Adds an enhanced customer profile page to WooCommerce My Account.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "automattic/vipwpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.5",
        "yoast/phpunit-polyfills": "^1.0",
        "10up/wp_mock": "^0.5"
    },
    "autoload": {
        "psr-4": {
            "WCCustomerProfilePage\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WCCustomerProfilePage\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "test": "phpunit",
        "make-pot": "wp i18n make-pot . languages/customer-profile-page-for-woocommerce.pot --domain=customer-profile-page-for-woocommerce --exclude=vendor,tests"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
